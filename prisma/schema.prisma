generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model College {
  id         String   @id @default(uuid())
  name       String
  domain     String   @unique
  is_active  Boolean  @default(true)
  created_at DateTime @default(now())

  users          User[]
  refresh_tokens RefreshToken[]

  @@map("colleges")
}

model User {
  id            String   @id @default(uuid())
  college_id    String
  email         String
  password_hash String
  full_name     String
  role          String   @default("student")
  is_active     Boolean  @default(true)
  created_at    DateTime @default(now())

  roll_no       String?
  image_url     String?
  class_name    String?
  sec           String?
  starting_year Int?
  ending_year   Int?
  branch        String?
  year          Int?

  college                        College                @relation(fields: [college_id], references: [id])
  refresh_tokens                 RefreshToken[]
  created_assignments            Assignment[]           @relation("AssignmentCreator")
  assignment_submissions         AssignmentSubmission[] @relation("AssignmentSubmissionStudent")
  graded_assignment_submissions  AssignmentSubmission[] @relation("AssignmentSubmissionGrader")

  @@unique([email, college_id])
  @@map("users")
}

model RefreshToken {
  id         String   @id @default(uuid())
  user_id    String
  college_id String
  token_hash String   @unique
  is_revoked Boolean  @default(false)
  expires_at DateTime
  created_at DateTime @default(now())

  user    User    @relation(fields: [user_id], references: [id])
  college College @relation(fields: [college_id], references: [id])

  @@map("refresh_tokens")
}

enum AssignmentStatus {
  DRAFT
  PUBLISHED
  CLOSED
}

enum SubmissionStatus {
  SUBMITTED
  GRADED
}

model Assignment {
  id          String           @id @default(uuid())
  college_id  String
  title       String
  description String
  subject     String
  class_name  String
  section     String?
  branch      String?
  year        Int?
  due_date    DateTime
  max_marks   Int              @default(100)
  status      AssignmentStatus @default(DRAFT)
  file_url    String?
  created_by  String
  created_at  DateTime         @default(now())
  updated_at  DateTime         @updatedAt

  creator     User                   @relation("AssignmentCreator", fields: [created_by], references: [id])
  submissions AssignmentSubmission[]

  @@index([college_id, class_name, section, branch, year, status])
  @@index([created_by])
  @@map("assignments")
}

model AssignmentSubmission {
  id             String           @id @default(uuid())
  assignment_id  String
  student_id     String
  college_id     String
  answer_text    String?
  file_url       String?
  marks_obtained Int?
  feedback       String?
  status         SubmissionStatus @default(SUBMITTED)
  submitted_at   DateTime         @default(now())
  graded_at      DateTime?
  graded_by      String?

  assignment Assignment @relation(fields: [assignment_id], references: [id], onDelete: Cascade)
  student    User       @relation("AssignmentSubmissionStudent", fields: [student_id], references: [id])
  grader     User?      @relation("AssignmentSubmissionGrader", fields: [graded_by], references: [id])

  @@unique([assignment_id, student_id])
  @@index([college_id, student_id])
  @@index([assignment_id])
  @@map("assignment_submissions")
}