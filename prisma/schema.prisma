generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model College {
  id                 String             @id @default(uuid())
  name               String
  domain             String             @unique
  is_active          Boolean            @default(true)
  created_at         DateTime           @default(now())
  attendance_records AttendanceRecord[]

  users          User[]
  refresh_tokens RefreshToken[]

  student_results       StudentResult[]
  college_subscriptions CollegeSubscription[]

  @@map("colleges")
}

model User {
  id            String   @id @default(uuid())
  college_id    String
  email         String
  password_hash String
  full_name     String
  role          String   @default("student")
  is_active     Boolean  @default(true)
  created_at    DateTime @default(now())

  roll_no       String?
  image_url     String?
  class_name    String?
  sec           String?
  starting_year Int?
  ending_year   Int?
  branch        String?
  year          Int?

  college                       College                @relation(fields: [college_id], references: [id])
  refresh_tokens                RefreshToken[]
  created_assignments           Assignment[]           @relation("AssignmentCreator")
  assignment_submissions        AssignmentSubmission[] @relation("AssignmentSubmissionStudent")
  graded_assignment_submissions AssignmentSubmission[] @relation("AssignmentSubmissionGrader")
  attendance_as_student         AttendanceRecord[]     @relation("StudentAttendance")
  attendance_marked             AttendanceRecord[]     @relation("AttendanceMarker")
  results_as_student            StudentResult[]        @relation("StudentResults")
  user_subscriptions            UserSubscription[]
  fee_invoices                  FeeInvoice[]
  payments                      Payment[]
  results_created               StudentResult[]        @relation("ResultCreator")

  @@unique([email, college_id])
  @@map("users")
}

model StudentResult {
  id             String   @id @default(uuid())
  college_id     String
  student_id     String
  subject        String
  exam_type      String
  semester       Int?
  academic_year  String
  max_marks      Int      @default(100)
  marks_obtained Float
  grade          String?
  result_status  String   @default("PASS")
  remarks        String?
  published      Boolean  @default(true)
  created_by     String?
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  college College @relation(fields: [college_id], references: [id])
  student User    @relation("StudentResults", fields: [student_id], references: [id])
  creator User?   @relation("ResultCreator", fields: [created_by], references: [id])

  @@unique([student_id, subject, exam_type, semester, academic_year])
  @@index([college_id, student_id])
  @@index([college_id, academic_year, semester, exam_type])
  @@map("student_results")
}

model RefreshToken {
  id         String   @id @default(uuid())
  user_id    String
  college_id String
  token_hash String   @unique
  is_revoked Boolean  @default(false)
  expires_at DateTime
  created_at DateTime @default(now())

  user    User    @relation(fields: [user_id], references: [id])
  college College @relation(fields: [college_id], references: [id])

  @@map("refresh_tokens")
}

model AttendanceRecord {
  id              String   @id @default(uuid())
  college_id      String
  student_id      String
  attendance_date DateTime @db.Date
  status          String   @default("ABSENT")
  marked_by       String?
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  college College @relation(fields: [college_id], references: [id])
  student User    @relation("StudentAttendance", fields: [student_id], references: [id])
  marker  User?   @relation("AttendanceMarker", fields: [marked_by], references: [id])

  @@unique([student_id, attendance_date])
  @@index([college_id, attendance_date])
  @@index([college_id, attendance_date, status])
  @@map("attendance_records")
}

enum AssignmentStatus {
  DRAFT
  PUBLISHED
  CLOSED
}

enum SubmissionStatus {
  SUBMITTED
  GRADED
}

model Assignment {
  id          String           @id @default(uuid())
  college_id  String
  title       String
  description String
  subject     String
  class_name  String
  section     String?
  branch      String?
  year        Int?
  due_date    DateTime
  max_marks   Int              @default(100)
  status      AssignmentStatus @default(DRAFT)
  file_url    String?
  created_by  String
  created_at  DateTime         @default(now())
  updated_at  DateTime         @updatedAt

  creator     User                   @relation("AssignmentCreator", fields: [created_by], references: [id])
  submissions AssignmentSubmission[]

  @@index([college_id, class_name, section, branch, year, status])
  @@index([created_by])
  @@map("assignments")
}

model AssignmentSubmission {
  id             String           @id @default(uuid())
  assignment_id  String
  student_id     String
  college_id     String
  answer_text    String?
  file_url       String?
  marks_obtained Int?
  feedback       String?
  status         SubmissionStatus @default(SUBMITTED)
  submitted_at   DateTime         @default(now())
  graded_at      DateTime?
  graded_by      String?

  assignment Assignment @relation(fields: [assignment_id], references: [id], onDelete: Cascade)
  student    User       @relation("AssignmentSubmissionStudent", fields: [student_id], references: [id])
  grader     User?      @relation("AssignmentSubmissionGrader", fields: [graded_by], references: [id])

  @@unique([assignment_id, student_id])
  @@index([college_id, student_id])
  @@index([assignment_id])
  @@map("assignment_submissions")
}

enum PaymentPurpose {
  COLLEGE_FEE
  SAAS_SUBSCRIPTION
  COLLEGE_SUBSCRIPTION
}

enum PaymentStatus {
  CREATED
  PAID
  FAILED
  REFUNDED
}

enum FeeInvoiceStatus {
  DUE
  PARTIAL
  PAID
  CANCELLED
}

enum SubscriptionStatus {
  ACTIVE
  EXPIRED
  CANCELLED
}

model SaasPlan {
  id            String   @id @default(uuid())
  code          String   @unique
  name          String
  amount_paise  Int
  duration_days Int
  is_active     Boolean  @default(true)
  created_at    DateTime @default(now())

  subscriptions         UserSubscription[]
  college_subscriptions CollegeSubscription[]

  @@map("saas_plans")
}

model UserSubscription {
  id         String             @id @default(uuid())
  college_id String
  user_id    String
  plan_id    String
  status     SubscriptionStatus @default(ACTIVE)
  starts_at  DateTime
  expires_at DateTime
  created_at DateTime           @default(now())
  updated_at DateTime           @updatedAt

  user User     @relation(fields: [user_id], references: [id])
  plan SaasPlan @relation(fields: [plan_id], references: [id])

  @@index([college_id, user_id])
  @@map("user_subscriptions")
}

model FeeInvoice {
  id                 String           @id @default(uuid())
  college_id         String
  student_id         String
  invoice_no         String
  total_amount_paise Int
  paid_amount_paise  Int              @default(0)
  status             FeeInvoiceStatus @default(DUE)
  due_date           DateTime?
  created_at         DateTime         @default(now())
  updated_at         DateTime         @updatedAt

  student  User             @relation(fields: [student_id], references: [id])
  items    FeeInvoiceItem[]
  payments Payment[]
  receipts FeeReceipt[]

  @@unique([college_id, invoice_no])
  @@index([college_id, student_id, status])
  @@map("fee_invoices")
}

model FeeInvoiceItem {
  id             String @id @default(uuid())
  fee_invoice_id String
  head_name      String
  amount_paise   Int

  invoice FeeInvoice @relation(fields: [fee_invoice_id], references: [id], onDelete: Cascade)

  @@map("fee_invoice_items")
}

model Payment {
  id                  String         @id @default(uuid())
  college_id          String
  user_id             String?
  plan_id             String?
  purpose             PaymentPurpose
  amount_paise        Int
  currency            String         @default("INR")
  status              PaymentStatus  @default(CREATED)
  razorpay_order_id   String         @unique
  razorpay_payment_id String?        @unique
  razorpay_signature  String?
  fee_invoice_id      String?
  created_at          DateTime       @default(now())
  paid_at             DateTime?

  user       User?       @relation(fields: [user_id], references: [id])
  feeInvoice FeeInvoice? @relation(fields: [fee_invoice_id], references: [id])
  receipt    FeeReceipt?

  @@index([college_id, user_id, purpose, status])
  @@map("payments")
}

model FeeReceipt {
  id             String   @id @default(uuid())
  college_id     String
  student_id     String
  fee_invoice_id String
  payment_id     String   @unique
  receipt_no     String
  amount_paise   Int
  generated_at   DateTime @default(now())

  invoice FeeInvoice @relation(fields: [fee_invoice_id], references: [id])
  payment Payment    @relation(fields: [payment_id], references: [id])

  @@unique([college_id, receipt_no])
  @@map("fee_receipts")
}

model Notification {
  id         String    @id @default(uuid())
  college_id String
  user_id    String
  title      String
  body       String
  type       String
  data_json  Json?
  read_at    DateTime?
  created_at DateTime  @default(now())

  @@index([college_id, user_id, read_at])
  @@map("notifications")
}

model UserDevice {
  id         String   @id @default(uuid())
  user_id    String
  college_id String
  fcm_token  String   @unique
  platform   String?
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([user_id])
  @@map("user_devices")
}

model RazorpayWebhookEvent {
  id         String   @id @default(uuid())
  event_id   String   @unique
  event_name String
  processed  Boolean  @default(false)
  created_at DateTime @default(now())

  @@map("razorpay_webhook_events")
}

model CollegeSubscription {
  id         String             @id @default(uuid())
  college_id String
  plan_id    String
  status     SubscriptionStatus @default(ACTIVE)
  starts_at  DateTime
  expires_at DateTime
  created_at DateTime           @default(now())
  updated_at DateTime           @updatedAt

  college College  @relation(fields: [college_id], references: [id])
  plan    SaasPlan @relation(fields: [plan_id], references: [id])

  @@index([college_id, status])
  @@map("college_subscriptions")
}
